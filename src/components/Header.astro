---
export type CurrentPage = 'home' | 'manifesto' | 'roadmap' | 'fosdem';

interface Props {
  current: CurrentPage;
}

const { current } = Astro.props;

const brandHref = current === 'home' ? '#top' : 'index.html';

const crossLink = (hash: string) => (current === 'home' ? `#${hash}` : `index.html#${hash}`);

const roadmapItem =
  current === 'roadmap'
    ? { href: '#top', label: 'Roadmap' }
    : { href: 'roadmap.html', label: 'Roadmap' };

const fifthItem =
  current === 'home'
    ? { href: '#get-started', label: 'Get started' }
    : current === 'manifesto'
      ? { href: '#top', label: 'Manifesto' }
      : { href: 'index.html#get-started', label: 'Get started' };
---

<header class="site-nav">
  <div class="wrap nav-inner">
    <a href={brandHref} class="brand">
      <img src="assets/logo-docs-oss.svg" width="87" height="35" alt="Docs">
    </a>
    <nav class="nav-links" id="navLinks">
      <a href={crossLink('features')}>Features</a>
      <a href={crossLink('ai')}>AI</a>
      <a href={crossLink('commons')}>Open source</a>
      <a href={roadmapItem.href}>{roadmapItem.label}</a>
      <a href={fifthItem.href}>{fifthItem.label}</a>
      <a href={crossLink('faq')}>FAQ</a>
    </nav>
    <div class="nav-cta">
      <a class="btn btn-secondary" href="https://github.com/suitenumerique/docs" target="_blank" rel="noopener">
        <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.23.48-2.7-1.07-2.7-1.07-.36-.93-.89-1.17-.89-1.17-.72-.5.06-.49.06-.49.8.06 1.23.83 1.23.83.71 1.22 1.87.87 2.33.67.07-.52.28-.87.5-1.08-1.78-.2-3.65-.89-3.65-3.96 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.22 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.08-1.87 3.75-3.66 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8 8 0 0 0 8 0Z"/></svg>
        16.6k
      </a>
      <a class="btn btn-primary" href="https://docs.la-suite.eu/docs/9137bbb5-3e8a-4ff7-8a36-fcc4e8bd57f4/" target="_blank" rel="noopener">Try the demo</a>
      <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false" aria-controls="navLinks"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>
