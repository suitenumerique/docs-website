---
import type { CurrentPage } from './Header.astro';

interface Props {
  current: CurrentPage;
}

const { current } = Astro.props;

// Same rationale as Header.astro: root-relative so this still resolves
// correctly from nested pages like /roadmap/<slug>.
const base = (import.meta.env.BASE_URL + '/').replace('//', '/');

const footerDesc =
  current === 'manifesto'
    ? "An open-source, self-hostable alternative to Notion or Google Docs — built as a digital commons, for anyone to run."
    : "An open-source, self-hostable text editor — built as a digital commons, for anyone to run.";

---

<footer>
  <div class="wrap">
    <div class="footer-top">
      <div>
        <div class="footer-brand">
          <img src={`${base}assets/icon-docs.svg`} width="32" height="32" alt="">
          Docs
        </div>
        <p class="footer-desc">{footerDesc}</p>
      </div>
      <div class="footer-col">
        <h3>Project</h3>
        <ul>
          <li><a href={`${base}index.html#features`}>Features</a></li>
          <li><a href={`${base}index.html#ai`}>AI</a></li>
          <li><a href={`${base}index.html#commons`}>Open source</a></li>
          <li><a href={`${base}roadmap.html`}>Roadmap</a></li>
          <li><a href={`${base}manifesto.html`}>Manifesto</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Resources</h3>
        <ul>
          <li><a href="https://github.com/suitenumerique/docs" target="_blank" rel="noopener">Source code</a></li>
          <li><a href="https://github.com/suitenumerique/docs/blob/main/docs/installation/README.md" target="_blank" rel="noopener">Installation guide</a></li>
          <li><a href="https://github.com/suitenumerique/docs/blob/main/docs/instances.md" target="_blank" rel="noopener">Public instances</a></li>
          <li><a href="https://github.com/suitenumerique/docs/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener">Contributing guide</a></li>
          <li><a href="https://digitalpublicgoods.net/r/docs-collaborative-text-editing" target="_blank" rel="noopener">Digital Public Good listing</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Community</h3>
        <ul>
          <li><a href={`${base}community-calls.html`}>Community calls</a></li>
          <li><a href={`${base}fosdem.html`}>FOSDEM talks</a></li>
          <li><a href="https://matrix.to/#/#docs-official:matrix.org" target="_blank" rel="noopener">Chat on Matrix</a></li>
          <li><a href="https://github.com/suitenumerique/docs/issues" target="_blank" rel="noopener">Report an issue</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>Docs is free and open-source software, released under the MIT license.</span>
    </div>
  </div>
</footer>
