---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { fetchManifestoHtml } from '../lib/manifesto';

const contentHtml = await fetchManifestoHtml();
---

<Layout title="Manifesto — Docs" description="Stop pretending it's paper. Why the office document is a costume software still wears, and why we built Docs to take it off.">
  <Header current="manifesto" />

<main id="top">

  <!-- ================= MANIFESTO ================= -->
  <section class="article">
    <div class="wrap">
      <div class="eyebrow reveal in">Manifesto</div>
      <Fragment set:html={contentHtml} />
    </div>
  </section>

  <!-- ================= FINAL CTA ================= -->
  <section>
    <div class="wrap">
      <div class="cta-band reveal">
        <h2>Ready to stop formatting and start writing?</h2>
        <p>No blank page. No ruler. No margins that mean nothing.</p>
        <div class="hero-ctas">
          <a class="btn btn-primary btn-lg" href="https://demo.docs.la-suite.eu/docs/6d1b6f7f-db33-4673-9277-4bf47b9881ec/" target="_blank" rel="noopener">Open a live demo document →</a>
          <a class="btn btn-secondary btn-lg" href="roadmap.html">See the roadmap</a>
        </div>
      </div>
    </div>
  </section>

</main>

  <Footer current="manifesto" />
</Layout>
