---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RoadmapItem from '../components/RoadmapItem.astro';
import { fetchRoadmapRoot } from '../lib/roadmap';

const { introHtml, contributeLead, contributeItems } = await fetchRoadmapRoot();
---

<Layout title="Roadmap — Docs" description="How Docs gets built: the public institutions funding it, the open-source dependencies it relies on, what's planned next, and what's already shipped.">
  <Header current="roadmap" />

<main id="top">

  <!-- ================= INTRO ================= -->
  <section class="article">
    <div class="wrap">
      <div class="eyebrow reveal in">Roadmap</div>
      <h1 class="reveal in">How Docs gets built</h1>
      <Fragment set:html={introHtml} />
      <figure class="xkcd-figure reveal">
        <img src="assets/xkcd-dependency.png" width="770" height="978" alt="xkcd comic 'Dependency': a towering, precarious stack of blocks labeled 'All modern digital infrastructure' balanced entirely on one small block, with an arrow reading 'A project some random person in Nebraska has been thanklessly maintaining since 2003'.">
        <figcaption>"Dependency," <a href="https://xkcd.com/2347/" target="_blank" rel="noopener">xkcd</a> — CC BY-NC 2.5</figcaption>
      </figure>
    </div>
  </section>

  <!-- ================= CONTRIBUTE / LOOKING FOR FUNDING ================= -->
  <section id="contribute" style="background:var(--gray-025);">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="eyebrow">Contribute</div>
        <h2>Contribute to Docs!</h2>
        {contributeLead && <p>{contributeLead}</p>}
      </div>
      <div class="roadmap-list">
        {contributeItems.map((item) => <RoadmapItem item={item} />)}
      </div>
    </div>
  </section>

  <!-- ================= FINAL CTA ================= -->
  <section>
    <div class="wrap">
      <div class="cta-band reveal">
        <h2>Want to help shape what's next?</h2>
        <p>Open an issue, join the discussion, or fund a feature your organization needs.</p>
        <div class="hero-ctas">
          <a class="btn btn-primary btn-lg" href="https://github.com/suitenumerique/docs/issues" target="_blank" rel="noopener">Open an issue</a>
          <a class="btn btn-secondary btn-lg" href="https://matrix.to/#/#docs-official:matrix.org" target="_blank" rel="noopener">Chat on Matrix</a>
        </div>
      </div>
    </div>
  </section>

</main>

  <Footer current="roadmap" />
</Layout>
